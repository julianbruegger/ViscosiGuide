---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ViscosiGuide — Neues Passwort" active="">
  <section class="vg-panel" style="max-width:460px;margin:0 auto;">
    <h2>🔐 Neues Passwort setzen</h2>
    <div id="vg-msg"></div>
    <form id="vg-form">
      <div class="vg-field">
        <label for="password">Neues Passwort</label>
        <input id="password" type="password" class="vg-input" required minlength="10" autocomplete="new-password" />
        <p class="vg-hint">Mindestens 10 Zeichen.</p>
      </div>
      <button type="submit" class="vg-btn vg-btn--primary">Passwort speichern</button>
    </form>
    <p class="vg-hint"><a href="/login">Zum Login</a></p>
  </section>

  <script>
    import { resetPassword, ApiError } from '../lib/api';
    import { showMessage } from '../lib/ui';

    const msg = document.getElementById('vg-msg')!;
    const form = document.getElementById('vg-form') as HTMLFormElement;
    const token = new URLSearchParams(window.location.search).get('token') || '';
    if (!token) {
      showMessage(msg, 'Kein Reset-Token gefunden.', 'error');
      form.hidden = true;
    }
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      try {
        const res = await resetPassword(token, password);
        showMessage(msg, res.message, 'ok');
        form.hidden = true;
      } catch (err) {
        showMessage(msg, err instanceof ApiError ? err.message : 'Fehlgeschlagen.', 'error');
      }
    });
  </script>
</BaseLayout>
