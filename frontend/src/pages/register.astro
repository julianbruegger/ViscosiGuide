---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ViscosiGuide — Registrieren" active="">
  <section class="vg-panel" style="max-width:460px;margin:0 auto;">
    <h2>📝 Konto erstellen</h2>
    <div id="vg-msg"></div>
    <form id="vg-form">
      <div class="vg-field">
        <label for="name">Anzeigename</label>
        <input id="name" class="vg-input" required minlength="2" maxlength="80" autocomplete="nickname" />
      </div>
      <div class="vg-field">
        <label for="email">E-Mail</label>
        <input id="email" type="email" class="vg-input" required autocomplete="email" />
      </div>
      <div class="vg-field">
        <label for="password">Passwort</label>
        <input id="password" type="password" class="vg-input" required minlength="10" autocomplete="new-password" />
        <p class="vg-hint">Mindestens 10 Zeichen.</p>
      </div>
      <button type="submit" class="vg-btn vg-btn--primary">Registrieren</button>
    </form>
    <hr class="vg-rule" />
    <p class="vg-hint">Schon ein Konto? <a href="/login">Login</a></p>
  </section>

  <script>
    import { register, ApiError } from '../lib/api';
    import { showMessage } from '../lib/ui';

    const msg = document.getElementById('vg-msg')!;
    const form = document.getElementById('vg-form') as HTMLFormElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const display_name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      try {
        const res = await register(email, password, display_name);
        showMessage(msg, res.message + ' Prüfe dein Postfach und bestätige deine E-Mail.', 'ok');
        form.reset();
      } catch (err) {
        const text = err instanceof ApiError ? err.message : 'Registrierung fehlgeschlagen.';
        showMessage(msg, text, 'error');
      }
    });
  </script>
</BaseLayout>
