---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ViscosiGuide — Passwort vergessen" active="">
  <section class="vg-panel" style="max-width:460px;margin:0 auto;">
    <h2>🔓 Passwort zurücksetzen</h2>
    <div id="vg-msg"></div>
    <form id="vg-form">
      <div class="vg-field">
        <label for="email">E-Mail</label>
        <input id="email" type="email" class="vg-input" required autocomplete="email" />
      </div>
      <button type="submit" class="vg-btn vg-btn--primary">Reset-Link senden</button>
    </form>
    <hr class="vg-rule" />
    <p class="vg-hint"><a href="/login">Zurück zum Login</a></p>
  </section>

  <script>
    import { requestReset, ApiError } from '../lib/api';
    import { showMessage } from '../lib/ui';

    const msg = document.getElementById('vg-msg')!;
    document.getElementById('vg-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      try {
        const res = await requestReset(email);
        showMessage(msg, res.message, 'ok');
      } catch (err) {
        showMessage(msg, err instanceof ApiError ? err.message : 'Fehlgeschlagen.', 'error');
      }
    });
  </script>
</BaseLayout>
